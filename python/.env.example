# Fio banking API token - vygeneruj v internetbankingu Fio
FIO_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL PHP backendu (bez koncového lomítka)
BACKEND_URL=https://virtualniazyl.cz/shop-api

# API klíč (musí se shodovat s parameters.shopApi.key v secrets.neon)
BACKEND_API_KEY=DLOUHY_NAHODNY_KLIC_MIN_40_ZNAKU

# Interval mezi voláními Fio API v sekundách
POLL_INTERVAL=30

# Kam logovat (volitelné, default = stdout)
LOG_FILE=/var/log/vaz-bankdaemon.log
