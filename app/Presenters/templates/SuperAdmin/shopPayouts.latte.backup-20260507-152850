{templateType App\Presenters\Templates\SuperAdmin\Layout}
{block superAdminContent}
<div class="container-fluid pt-4 px-4">

    {* Top status bar *}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-title">K vyplacení (pending)</h6>
                    <h3 class="mb-0">{$stats['pendingPayouts']|number:0,',','&nbsp;'|noescape} Kč</h3>
                    <small>{$stats['pendingPayoutsCount']} položek</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-warning">
                <div class="card-body">
                    <h6 class="card-title">Vratky k odeslání</h6>
                    <h3 class="mb-0">{$stats['pendingRefunds']|number:0,',','&nbsp;'|noescape} Kč</h3>
                    <small>{$stats['pendingRefundsCount']} položek</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-info text-white">
                <div class="card-body">
                    <h6 class="card-title">Zisk spolku (tento měsíc)</h6>
                    <h3 class="mb-0">{$stats['feesThisMonth']|number:0,',','&nbsp;'|noescape} Kč</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 {if $pythonAlive}bg-success{else}bg-danger{/if} text-white">
                <div class="card-body">
                    <h6 class="card-title">Python daemon</h6>
                    {if $pythonAlive}
                        <h5 class="mb-0"><i class="bi bi-check-circle"></i> Aktivní</h5>
                        <small>heartbeat {$lastHeartbeat|date:'H:i:s'}</small>
                    {else}
                        <h5 class="mb-0"><i class="bi bi-x-circle"></i> NEBĚŽÍ!</h5>
                        <small>{if $lastHeartbeat}naposled {$lastHeartbeat|date:'d.m. H:i'}{else}nikdy{/if}</small>
                    {/if}
                </div>
            </div>
        </div>
    </div>

    <div class="bg-light rounded p-4 mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="mb-0"><i class="bi bi-cash-stack me-2"></i>Platební dávky</h4>
            <div>
                <a href="{link SuperAdmin:shopBatches}" class="btn btn-outline-primary">
                    Všechny dávky
                </a>
            </div>
        </div>

        {* Pending payouts *}
        <h5 class="mt-3">Výplaty azylům ({count($pendingPayouts)})</h5>
        {if count($pendingPayouts) > 0}
            <form n:name="createBatchForm">
                <div class="table-responsive mb-3">
                    <table class="table table-sm table-hover align-middle">
                        <thead>
                            <tr>
                                <th style="width:40px;">
                                    <input type="checkbox" id="select-all-payouts">
                                </th>
                                <th>Objednávka</th>
                                <th>Azyl</th>
                                <th>Účet</th>
                                <th class="text-end">Částka</th>
                                <th class="text-end">Provize</th>
                                <th>Vytvořeno</th>
                            </tr>
                        </thead>
                        <tbody>
                            {foreach $pendingPayouts as $payout}
                                <tr>
                                    <td>
                                        <input type="checkbox" name="payout_ids[]"
                                               value="{$payout->getId()}" class="payout-check">
                                    </td>
                                    <td>
                                        <a href="{link SuperAdmin:shopOrderDetail, $payout->getOrder()->getId()}"
                                           class="font-monospace">{$payout->getOrder()->getOrderNumber()}</a>
                                    </td>
                                    <td>{$payout->getAzyl()->getAzylName()}</td>
                                    <td class="font-monospace small">
                                        {$payout->getFullAccount()}
                                    </td>
                                    <td class="text-end fw-bold">
                                        {$payout->getAmount()|number:2,',','&nbsp;'|noescape} Kč
                                    </td>
                                    <td class="text-end text-muted small">
                                        {$payout->getFeeAmount()|number:2,',','&nbsp;'|noescape} Kč
                                    </td>
                                    <td class="small">{$payout->getCreatedAt()|date:'d.m. H:i'}</td>
                                </tr>
                            {/foreach}
                        </tbody>
                    </table>
                </div>

                {* Pending refunds *}
                {if count($pendingRefunds) > 0}
                    <h5 class="mt-4">Vratky ({count($pendingRefunds)})</h5>
                    <div class="table-responsive mb-3">
                        <table class="table table-sm table-hover align-middle">
                            <thead>
                                <tr>
                                    <th style="width:40px;">
                                        <input type="checkbox" id="select-all-refunds">
                                    </th>
                                    <th>Objednávka</th>
                                    <th>Příjemce</th>
                                    <th>Účet</th>
                                    <th class="text-end">Částka</th>
                                    <th>Důvod</th>
                                </tr>
                            </thead>
                            <tbody>
                                {foreach $pendingRefunds as $refund}
                                    <tr>
                                        <td>
                                            <input type="checkbox" name="refund_ids[]"
                                                   value="{$refund->getId()}" class="refund-check">
                                        </td>
                                        <td class="font-monospace">{$refund->getOrder()->getOrderNumber()}</td>
                                        <td>{$refund->getRefundReceiverName() ?? '—'}</td>
                                        <td class="font-monospace small">
                                            {$refund->getRefundAccount()}/{$refund->getRefundBankCode()}
                                        </td>
                                        <td class="text-end fw-bold text-danger">
                                            {$refund->getAmount()|number:2,',','&nbsp;'|noescape} Kč
                                        </td>
                                        <td class="small">{$refund->getReason()}</td>
                                    </tr>
                                {/foreach}
                            </tbody>
                        </table>
                    </div>
                {/if}

                <div class="d-flex gap-2">
                    <button class="btn btn-primary" n:name="createBatch">
                        <i class="bi bi-box-arrow-up me-1"></i>Vytvořit platební dávku z vybraných
                    </button>
                    <button type="button" class="btn btn-outline-secondary"
                            onclick="selectAll(true)">Vybrat vše</button>
                    <button type="button" class="btn btn-outline-secondary"
                            onclick="selectAll(false)">Zrušit výběr</button>
                </div>
            </form>
        {else}
            <div class="alert alert-info">
                <i class="bi bi-check-circle me-2"></i>
                Všechny výplaty jsou zpracované. Super práce!
            </div>
        {/if}
    </div>

    {* Historie *}
    {if count($recentBatches) > 0}
        <div class="bg-light rounded p-4">
            <h5>Poslední dávky</h5>
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Batch</th>
                        <th>Položek</th>
                        <th class="text-end">Suma</th>
                        <th class="text-center">Stav</th>
                        <th>Vytvořeno</th>
                        <th>Odesláno</th>
                        <th class="text-end">Akce</th>
                    </tr>
                </thead>
                <tbody>
                    {foreach $recentBatches as $batch}
                        <tr>
                            <td class="font-monospace">{$batch->getBatchNumber()}</td>
                            <td>{$batch->getItemCount()}</td>
                            <td class="text-end">
                                {$batch->getTotalAmount()|number:2,',','&nbsp;'|noescape} Kč
                            </td>
                            <td class="text-center">
                                <span class="badge {$batch->getBatchStatus()->badgeClass()}">
                                    {$batch->getBatchStatus()->label()}
                                </span>
                            </td>
                            <td class="small">{$batch->getCreatedAt()|date:'d.m. H:i'}</td>
                            <td class="small">
                                {if $batch->getSentAt()}{$batch->getSentAt()|date:'d.m. H:i'}{else}—{/if}
                            </td>
                            <td class="text-end">
                                <a href="{link SuperAdmin:shopBatch, $batch->getId()}"
                                   class="btn btn-sm btn-outline-primary">Detail</a>
                            </td>
                        </tr>
                    {/foreach}
                </tbody>
            </table>
        </div>
    {/if}
</div>

<script>
    document.getElementById('select-all-payouts')?.addEventListener('change', function() {
        document.querySelectorAll('.payout-check').forEach(cb => cb.checked = this.checked);
    });
    document.getElementById('select-all-refunds')?.addEventListener('change', function() {
        document.querySelectorAll('.refund-check').forEach(cb => cb.checked = this.checked);
    });
    function selectAll(v) {
        document.querySelectorAll('.payout-check, .refund-check').forEach(cb => cb.checked = v);
    }
</script>
{/block}
