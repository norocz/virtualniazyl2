{templateType App\Presenters\Templates\SuperAdmin\Layout}
{block superAdminContent}
<div class="container-fluid pt-4 px-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="bg-light rounded p-4">
                <h4 class="mb-4"><i class="bi bi-key me-2"></i>Změna hesla</h4>

                <div class="alert alert-warning small">
                    <i class="bi bi-shield-exclamation me-1"></i>
                    Jste SuperAdmin. Heslo chraňte obzvlášť pečlivě — má přístup ke všem datům systému.
                    Doporučujeme alespoň 12 znaků s kombinací velkých/malých písmen, čísel a speciálních znaků.
                </div>

                {ifset $passwordForm}
                    <form n:name="passwordForm">
                        <div class="mb-3">
                            <label class="form-label" n:name="currentPassword">Aktuální heslo</label>
                            <input class="form-control" type="password" n:name="currentPassword">
                        </div>
                        <div class="mb-3">
                            <label class="form-label" n:name="newPassword">Nové heslo</label>
                            <input class="form-control" type="password" n:name="newPassword">
                        </div>
                        <div class="mb-3">
                            <label class="form-label" n:name="confirmPassword">Nové heslo znovu</label>
                            <input class="form-control" type="password" n:name="confirmPassword">
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-danger" n:name="save">
                                <i class="bi bi-check-lg me-1"></i>Změnit heslo
                            </button>
                            <a href="{link SuperAdmin:account}" class="btn btn-outline-secondary">Zrušit</a>
                        </div>
                    </form>
                {else}
                    <div class="alert alert-warning">Formulář není napojený.</div>
                {/ifset}
            </div>
        </div>
    </div>
</div>
{/block}

{block scripts}{/block}
