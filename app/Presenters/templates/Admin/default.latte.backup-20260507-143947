{block adminContent}
<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        <div class="col-sm-6 col-xl-3">
            <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-chart-line fa-3x text-primary"></i>
                <div class="ms-3">
                    <p class="mb-2">Registrace</p>
                    <h6 class="mb-0">{$newUsersCount}</h6>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-chart-bar fa-3x text-primary"></i>
                <div class="ms-3">
                    <p class="mb-2">Počet azylů</p>
                    <h6 class="mb-0">{$azylsCount}</h6>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-chart-area fa-3x text-primary"></i>
                <div class="ms-3">
                    <p class="mb-2">Počet Uživatelů</p>
                    <h6 class="mb-0">{$usersCount}</h6>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-chart-pie fa-3x text-primary"></i>
                <div class="ms-3">
                    <p class="mb-2">Přístupy</p>
                    <h6 class="mb-0">1235</h6>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="container-fluid pt-4 px-4">
    <div class="row g-4">
        <div class="col-sm-12 col-xl-6">
            <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">

                <div class="ms-3">
                    <h6 class="mb-2">Registrace po měsících</h6>
                    <div class="chart-container">
                        <canvas id="barChart-{$barId}" width="740" height="200"></canvas>
                    </div>
                    {* templates/Homepage/default.latte *}
                    {*include '../components/barChart.latte'*}

                </div>
            </div>
        </div>
        <div class="col-sm-12 col-xl-6">
            <div class="bg-light rounded d-flex align-items-center justify-content-between p-4">

                <div class="ms-3">
                    <h6 class="mb-2">Návštěvnost po dnech</h6>
                    <div class="chart-container">
                        <canvas id="lineChart-{$lineId}" width="740" height="200"></canvas>
                    </div>
                    {* templates/Homepage/default.latte *}
                    {*include '../components/barChart.latte'*}

                </div>
            </div>
        </div>
    </div>
</div>
{/block}

{block scripts}
    <script>
        const ctx = document.getElementById('barChart-' + {$barId}).getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: {$labels},
                datasets: [{
                    label: {$label},
                    data: {$data},
                    backgroundColor: 'rgba(75, 192, 192, 0.2)',
                    borderColor: 'rgba(75, 192, 192, 1)',
                    borderWidth: 1
                }]
            },
            options: {
                scales: { y: { beginAtZero: true } }
            }
        });

    </script>
    <script>

            const line = document.getElementById('lineChart-' + {$lineId}).getContext('2d');
            new Chart(line, {
            type: 'line',
            data: {
            labels: {$visitorsByDayLabel},
                datasets: [
                    {
                        label: 'Unikátní návštěvy za den',
                        data: {$visitorsByDayData},
                        backgroundColor: 'rgba(75, 192, 192, 0.2)',
                        borderColor: 'rgba(75, 192, 192, 1)',
                        borderWidth: 1
                    },
                    {
                        label: 'Zobrazení za den',
                        data: {$allVisitorsByDayData},
                        backgroundColor: 'rgba(255, 99, 132, 0.2)',
                        borderColor: 'rgba(255, 99, 132, 1)',
                        borderWidth: 1
                    }
                ]
        },
            options: {
            scales: {
            y: {
            beginAtZero: true
        }
        }
        }
        });

    </script>
{/block}

