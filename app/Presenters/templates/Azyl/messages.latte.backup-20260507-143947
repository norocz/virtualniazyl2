{block azylContent}
<style>
    /* Příchozí zprávy */
    .in {
        background-color: #d1e7dd;
        text-align: left;
        margin-left: 0;

    }

    /* Odchozí zprávy */
    .out{
        background-color: #f0f0f0;
        text-align: right;
        margin-left: auto;
        padding-right: 2em;
    }

    #chat-detail {
        width: 70%;
        background-color: #fff;
        padding: 20px;
        border-left: 1px solid #ddd;
        justify-content: flex-end; /* Zajišťuje, že se zprávy zarovnají dole */
        max-height: 80vh; /* Nastaví výšku chatu, můžeš upravit dle potřeby */
        overflow-y: auto; /* Umožňuje skrolování, pokud je více zpráv */
    }

</style>

<main class="main" id="top">
    <div class="bg">
        <div class="content">
            {ifset $chats}
            <div class="container-fluid pt-4 px-4">
                <div class="row g-4">

                    <div class="col-sm-12 col-md-6 col-xl-4">
                        <div class="h-100 bg-light rounded p-4">
                            <div class="chat d-flex align-items-center justify-content-between mb-2" id="chat">
                                 <h6 class="mb-0">Kontakty</h6>
                            </div>
                           {foreach $chats as $chat}

                                            <div class="d-flex align-items-center border-bottom py-3">
                                                <div class="w-100 ms-3">
                                                    <div class="d-flex w-100 justify-content-between">



                                                  <a class="ajax cont m-2 p-2 link-light btn-info rounded-3" style="min-width: auto;" n:href="chat! $chat->getId()">

                                                      {$chat->getUser()->getUserName()}</a>
                                                        {if $chat->getAdoption() != null}
                                                            <a class="m-2 p-2 link-light btn-success rounded-3" href="{link azyl:adoptions , $chat->getAdoption()->getId()}">Adopce: {$chat->getAdoption()->getAnimal()->getName()}</a>
                                                        {/if}
                                                    </div>
                                                </div>
                                            </div>

                                        {/foreach}
                        </div>
                    </div>

                    <div class="col-sm-12 col-md-6 col-xl-8">
                        <div class="h-100 bg-light rounded p-4" id="chat-detail">
                            <div class="messages d-flex align-items-center justify-content-between mb-4" id="messages">
                                <h6 class="mb-0">Vzkazy</h6>
                            </div>
                            {snippet messages}
                            {ifset $messages}

                            {foreach $messages as $message}

                            <div class="d-flex align-items-center border-bottom py-3" >
                                <div class="w-100 ms-3">
                                    <div class="d-flex w-100 justify-content-between">
                                        <div class="me-4 ps-4 p-3 shadow rounded-2 msg {if$message->getAzyl() == null}in{else}out{/if}">
                                        <span>{$message->getMessage()|safeHtml|noescape}</span><br>
                                       <span class="small">{$message->getCreatedAt()|date:'H:i d.m.Y'}</span>
                                    </div>
                                </div>
                            </div>
                            </div>

                                {/foreach}

                                <form n:name=messagesForm class="ajax form row col-auto m-2 " data-reciver="{$conversation}">
                                    <div class="msg-text-array col-lg-9">
                                        <label n:name=message><textarea class="font-monospace form-control ajax chat-textarray" cols="55" rows="2" n:name=message autofocus></textarea></label>
                                    </div>
                                    <div class="msg-text-array col-lg-3 ">
                                        <input n:name=address value="{$conversation}">
                                        <input class="align-center ajax chat-send btn btn-secondary" n:name=send>
                                    </div>

                                </form>

                                {/ifset}
                                {/snippet messages}

                         </div>
                      </div>
                    </div>
                   </div>
                 </div>
        {/ifset}
              </div>
        </main>

        {/block}
        {block scripts}
        {/block}
