<!DOCTYPE html>
<html data-bs-theme="light" lang="cs" dir="ltr" xmlns="http://www.w3.org/1999/html">

<head>
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1">

	<title>{ifset title}{include title|stripHtml} | {/ifset}Virtuální azyl</title>
	<!-- ===============================================-->
	<!--    Favicons-->
	<!-- ===============================================-->
	<link rel="apple-touch-icon" sizes="180x180" href="{$basePath}/assets/img/logos/dino180.png">
	<link rel="icon" type="image/png" sizes="32x32" href="{$basePath}/assets/img/logos/dino32.png">
	<link rel="icon" type="image/png" sizes="16x16" href="{$basePath}/assets/img/logos/dino16.png">
	<link rel="shortcut icon" type="image/x-icon" href="{$basePath}/assets/img/logos/dino.ico">
	<link rel="manifest" href="{$basePath}/assets/img/logos/manifest.json">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
	<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />

	<meta name="msapplication-TileImage" content="{$basePath}/assets/img/logos/dino150.png">
	<meta name="theme-color" content="#ffffff">
	<script src="{$basePath}/assets/js/config.js"></script>


	<!-- ===============================================-->
	<!--    Stylesheets-->
	<!-- ===============================================-->
	<link rel="stylesheet" href="{$basePath}/vendors/swiper/swiper-bundle.min.css">
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700&amp;display=swap" rel="stylesheet">
	<link href="{$basePath}/assets/css/theme.css" rel="stylesheet" id="style-default">
	<link href="{$basePath}/assets/css/user-rtl.css" rel="stylesheet" id="user-style-rtl">
	<link href="{$basePath}/assets/css/user.css" rel="stylesheet" id="user-style-default">
	<link rel="stylesheet" href="https://unicons.iconscout.com/release/v4.0.8/css/line.css">
	{ifset #head}
	{include head}
	{/ifset}
</head>


<body>
<style>
	.nav-small{ font-size: 1.15rem !important; }
	#cookieConsent {
		position: fixed;
		bottom: 0;
		width: 50%;
		z-index: 1000;




	}
</style>

	{block firstmenu}
<main class="main" id="top">
	<div class="bg-white">
		<div class="content">
        <div class="bg-white p-1 p-lg-2">
            <div class="container">
				<div id="cookieConsent" class="alert alert-info text-center" role="alert" style="display:none;">
					Tento web používá cookies při přihlašování uživatele. Nepoužívá cookies třetích stran (Google, Facebook a spol.)
					<button type="button" class="btn btn-primary btn-sm" id="acceptCookies">Rozumím</button>
				</div>
                <div class="d-flex justify-content-end align-items-center">
					<a class="ms-2 ms-md-3 submenu" href="{link Page:support}">
						<span class="uil uil-bill"></span>
						<span class="ms-1 fs-10 fs-sm-9">Podpora</span>
					</a>
					<a class="ms-2 ms-md-3 submenu" n:href="Home:news">
						<span class="uil uil-file-times"></span>
						<span class="ms-1 fs-10 fs-sm-9">Novinky</span>
					</a>
					<a class="ms-2 ms-md-3 submenu" href="{link Page:supporters}">
						<span class="uil uil-sperms">
						</span><span class="ms-1 fs-10 fs-sm-9">Podpořili</span>
					</a>
					{if $user->isLoggedIn()}
					<a class="ms-2 ms-md-3 submenu" href="{link User:messages}">
						{snippet messagesCount}
							<span class="ajax uil uil-mailbox"> {if ($messagesCount ?? 0) > 0}<span class="rounded" style="vertical-align: super; horiz-align: center; font-size: smaller; background-color: red; color: white;">&nbsp;{$messagesCount}&nbsp;</span>{/if}Kontakty</span>
						{/snippet}
					</a>
					<a class="ms-2 ms-md-3 submenu position-relative" href="{link Shop:cart}">
						<span class="uil uil-shopping-cart"></span>
						{if ($cartItemCount ?? 0) > 0}
							<span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.6rem;">
								{$cartItemCount}
							</span>
						{/if}
						<span class="ms-1 fs-10 fs-sm-9">Košík</span>
					</a>
					<a class="ms-2 ms-md-3 submenu" href="{link User:profil}">
						<span class="uil uil-user-circle">Profil</span>
					</a>
					<a class="ms-2 ms-md-3 submenu" href="{link Home:logOut}">
						<span class="uil uil-user-minus"></span>
						<span class="ms-1 fs-10 fs-sm-9 bg-white">Odhlásit</span>
					</a>
					{else}
					<a class="ms-2 ms-md-3 submenu" href="{link Home:registration}">
						<span class="uil uil-user-plus"></span>
						<span class="ms-1 fs-10 fs-sm-9">Registrace</span>
					</a>
					<a class="ms-2 ms-md-3 submenu" href="{link Home:signIn}">
						<span class="uil uil-user-circle"></span>
						<span class="ms-1 fs-10 fs-sm-9">Přihlášení</span>
					</a>
					{/if}
                </div>
            </div>
    {/block}
    {block mainmenu}
				<nav class="navbar navbar-expand-lg py-1" id="navbar-top" data-navbar-soft-on-scroll="data-navbar-soft-on-scroll">
					<div class="container"><a class="navbar-brand me-lg-auto cursor-pointer" href="{link Home:default}"><img style="max-height: 80px;" class="w-50 w-md-100 img-fluid" src="{$basePath}/assets/vazdata/img/logos/header_logo_green.png" alt="" /></a><button class="navbar-toggler border-0 pe-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation"><span class="navbar-toggler-icon"></span></button>
						<div class="collapse navbar-collapse justify-content-end" id="navbarSupportedContent" data-navbar-collapse="data-navbar-collapse">
							<div class="container d-lg-flex justify-content-lg-end pe-lg-0 w-lg-100">
								<ul n:ifset="$mainMenuItems" class="navbar-nav mt-2 mt-lg-1 ms-lg-4 ms-xl-8 ms-2xl-9 gap-lg-x1" data-navbar-nav="data-navbar-nav">
									<li n:foreach="$mainMenuItems as $item" n:if="$item['alwaysAvailable'] || ($item['logged'] && $user->isLoggedIn() && (!$item['role'] || $user->isInRole($item['role'])))" class="nav-item">

										<a n:href="$item['link']" n:class="nav-link, nav-bar-item, nav-small, px-0,fs-6, isLinkCurrent($item['link']) ? active">
											{$item['name']}
											{if $item['link'] === 'Azyl:default' && ($azylUnreadCount ?? 0) > 0}
												<span class="badge bg-danger ms-1" style="font-size:10px;">{$azylUnreadCount}</span>
											{/if}
										</a>
									</li>
								</ul>
							</div>
						</div>
					</div>
				</nav>




    {/block}
<main class="main" id="top">
	<div class="toast-container position-fixed bottom-0 start-0 p-3">
		<div	n:foreach="$flashes as $flash"
				id="flash-toast-{$iterator->counter}"
				class="toast"
				role="alert"
				aria-live="assertive"
				aria-atomic="true"
				data-bs-autohide="true"
				data-bs-delay="5000">
			<div class="toast-header {if $flash->type === 'alert-success'}bg-success text-white{elseif $flash->type === 'alert-warning'}bg-danger text-white{else}bg-info text-white{/if}">
            <span class="me-auto">Informace
                {if $flash->type === 'alert-success'}
					<i class="bi bi-check-circle-fill text-success"></i>
                {elseif $flash->type === 'alert-warning'}
                    <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                {else}
                    <i class="bi bi-info-circle-fill text-info"></i>
				{/if}

            </span>
				<button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
			</div>
			<div class="toast-body">
				{$flash->message}
			</div>
		</div>
	</div>



	<div class="container-lg">



				{include content}
			</div>
		</div>
	</div>




	<footer class="Footer" style="background-image: url('{$basePath}/assets/img/illustrations/BOTTOM.png')">
		<div class="pb-x1 px-3 px-lg-0">
			<div class="container">
				<div class="row align-items-end g-4 g-sm-6">
					<div class="col-6 col-md-4">
						<div class="mb-6 mb-md-8"><a class="cursor-pointer" href=""><img class="img-fluid" src="{$basePath}/assets/vazdata/img/logos/footer_logo_white.png" alt="" /></a></div>
						<div>
							<div class="mb-2"> <a class="links" href="{link Home:default}">Hlavní stránka</a></div>
							<div class="mb-2"> <a class="links" href="{link Page:onas}">O nás</a></div>
							<div class="mb-2"> <a class="links" href="{link Home:azyls}">Azyly</a></div>
							<div class="mb-2"> <a class="links" href="{link Home:adoptions}">Zvířátka k adopci</a></div>
							<a class="links" href="{link Page:support}">Podpořte nás!</a>
						</div>
					</div>
					<div class="col-6 col-md-4">
						<div class="mb-3 mb-md-5">
							<h3 class="fs-9 fs-md-8 fw-bold mb-0" style="color: #FFF0D3;">Účet</h3>
						</div>
						<div>
							<div class="mb-2"> <a class="links" href="{link Home:registration}">Registrovat se</a></div>
							<div class="mb-2"> <a class="links" href="{link Home:signIn}">Přihlásit se </a></div>
							<div class="mb-2"> <a class="links" href="{link Home:news}">Novinky</a></div>
							<div class="mb-2"> <a class="links" href="https://veganforum.cz/viewforum.php?f=3">Chyby a nápady</a></div>
						</div>
					</div>
					<div class="col-12 col-md-4">
						<div class="row g-4 g-sm-6 g-md-0">
							<div class="col-6 col-md-12 mb-md-7">
								<h3 class="fs-9 fs-md-8 fw-bold mb-3" style="color: #FFF0D3;">Možná jsme i tady</h3>
								<div class="d-flex align-items-center"> <a class="social-icon me-2" href="https://www.facebook.com/virtualniazyl"><span class="uil uil-facebook fs-8"></span></a><a class="social-icon me-2" href="https://www.instagram.com/virtualniazylcz/"><span class="uil uil-instagram fs-8"></span></a></div>
							</div>
							<div class="col-6 col-md-12">

								<div class="fs-10 fs-md-9">
									<p class="mb-0 text-white opacity-70"> &copy; 2024 - 2025 Virtuální azyl z.s.</p>
									<p>Verze: {$version['number'] ?? ''} | sestavená: {$version['date'] ?? ''}</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
		<div class="bg-success py-2 py-md-3 position-relative terms-condition">
			<div class="overley-background"></div>
			<div class="container py-12 text-div text-md-end"><a class="links ms-md-4" href="{link Page:faq-ckd}" title="Č.K.D"> Č.K.D </a><a class="links ms-3 ms-md-4" href="{link Page:cookies}" title="Cookies Policy"> Politika Sušenek</a><a class="links ms-3 ms-md-4" href="{link Page:polici}" title="Legal Terms"> Podmínky užívání </a> <a class="links ms-3 ms-md-4" style = "color:#0d3025;" href="{link home:thanks}"> &pi;</a> </div>
		</div>
	</footer>
	</div>
	</div>
	</main>
{block scripts}
	<!-- ===============================================-->
	<!--    JavaScripts-->
	<!-- ===============================================-->
	<script src="{$basePath}/vendors/jquery/jquery.min.js"></script>
	<script src="{$basePath}/vendors/popper/popper.min.js"></script>
	<script src="{$basePath}/vendors/bootstrap/bootstrap.min.js"></script>
	<script src="{$basePath}/vendors/is/is.min.js"></script>
	<script src="{$basePath}/vendors/countup/countUp.umd.js"></script>
	<script src="{$basePath}/vendors/swiper/swiper-bundle.min.js"></script>
	<script src="{$basePath}/vendors/lodash/lodash.min.js"></script>

	<script src="{$basePath}/vendors/list.js/list.min.js"></script>
	<script src="{$basePath}/assets/js/theme.js"></script>
	<script src="{$basePath}/assets/js/Naja.min.js"></script>
	<script src="{$basePath}/assets/js/netteForms.js"></script>
	<script>document.addEventListener("DOMContentLoaded", () => naja.initialize());</script>

	<script>

		document.addEventListener('DOMContentLoaded', function() {
			// Zkontrolovat, zda je uživatel přihlášený - tato proměnná bude přicházet z PHP (Nette)
			var isLoggedIn = {$user->isLoggedIn() ? 'true' : 'false'};

			// Pokud uživatel není přihlášený a souhlas není uložený, zobraz banner
			if (!isLoggedIn && !localStorage.getItem('cookieConsent')) {
				document.getElementById('cookieConsent').style.display = 'block';
			}

			// Při kliknutí na tlačítko uložit souhlas
			document.getElementById('acceptCookies').addEventListener('click', function() {
				localStorage.setItem('cookieConsent', true);
				document.getElementById('cookieConsent').style.display = 'none';
			});
		});
		document.addEventListener("DOMContentLoaded", () => {
			// Najdi všechny toast prvky
			const toastElements = document.querySelectorAll('.toast');

			// Pro každý toast vytvoř instance Bootstrap Toast
			toastElements.forEach(toastElement => {
				const toast = new bootstrap.Toast(toastElement);
				toast.show(); // Zobraz toast
			});
		});

	</script>
{/block}
{include scripts-user}
</body>
</html>