{layout @layout.latte}

{block title}Nová objednávka {$order->getOrderNumber()} - čeká na platbu{/block}

{block content}
<h2 style="color:#fd7e14;margin:0 0 16px 0;font-size:20px;">
    📋 Nová objednávka ve Vašem eshopu
</h2>

<p style="margin:0 0 16px 0;">Dobrý den,</p>

<p style="margin:0 0 16px 0;">
    ve Vašem eshopu na Virtuálním azylu právě někdo vytvořil novou objednávku.
    <strong>Platba ještě nedorazila</strong> - jakmile zákazník zaplatí QR kódem na
    účet spolku, pošleme Vám další potvrzovací e-mail s detaily k odeslání.
</p>

<div style="background:#fff3cd;border-left:4px solid #ffc107;padding:16px 20px;margin:20px 0;border-radius:4px;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td style="padding:4px 0;"><strong>Číslo objednávky:</strong></td>
            <td style="padding:4px 0;text-align:right;font-family:monospace;font-weight:bold;">
                {$order->getOrderNumber()}
            </td>
        </tr>
        <tr>
            <td style="padding:4px 0;">Stav:</td>
            <td style="padding:4px 0;text-align:right;">
                <span style="background:#fd7e14;color:white;padding:2px 8px;border-radius:4px;font-size:12px;">
                    ⏳ Čeká na platbu
                </span>
            </td>
        </tr>
        <tr>
            <td style="padding:4px 0;">Platnost do:</td>
            <td style="padding:4px 0;text-align:right;">
                {$order->getExpiresAt()|date:'d.m.Y H:i'}
            </td>
        </tr>
    </table>
</div>

<h3 style="margin:24px 0 12px 0;font-size:16px;">Co zákazník objednal</h3>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse;font-size:14px;">
    {foreach $order->getItems() as $item}
        <tr>
            <td style="padding:8px 0;border-bottom:1px solid #eee;">
                <strong>{$item->getProductName()}</strong>
            </td>
            <td style="text-align:center;padding:8px 0;border-bottom:1px solid #eee;">
                {$item->getQuantity()}&times;
            </td>
            <td style="text-align:right;padding:8px 0;border-bottom:1px solid #eee;">
                {$item->getSubtotal()|number:0,',','&nbsp;'|noescape} Kč
            </td>
        </tr>
    {/foreach}
    <tr>
        <td colspan="3" style="padding:12px 0 0 0;text-align:right;">
            Objednávka celkem: <strong>{$order->getTotalAmount()|number:0,',','&nbsp;'|noescape} Kč</strong>
            <br><span style="color:#666;font-size:12px;">
                vám připadne {$order->getPayoutAmount()|number:0,',','&nbsp;'|noescape} Kč po zaplacení
            </span>
        </td>
    </tr>
</table>

<h3 style="margin:24px 0 12px 0;font-size:16px;">Komu bude odesláno</h3>

<div style="background:#f8f9fa;border-radius:6px;padding:16px 20px;">
    <p style="margin:0 0 6px 0;"><strong>{$order->getBuyerName()}</strong></p>
    <p style="margin:0 0 6px 0;font-size:14px;">{$order->getFullDeliveryAddress()}</p>
    <p style="margin:6px 0 0 0;font-size:13px;color:#666;">
        📧 {$order->getBuyerEmail()}
        {if $order->getBuyerPhone()} &nbsp;•&nbsp; 📞 {$order->getBuyerPhone()}{/if}
    </p>

    {if $order->getDeliveryNote()}
        <div style="margin-top:12px;padding-top:12px;border-top:1px solid #dee2e6;font-size:13px;">
            <strong>Poznámka zákazníka:</strong><br>
            {$order->getDeliveryNote()}
        </div>
    {/if}
</div>

<div style="background:#e7f3ff;border-left:4px solid #0d6efd;padding:16px 20px;margin:20px 0;border-radius:4px;font-size:13px;">
    <p style="margin:0 0 6px 0;"><strong>💡 Co teď:</strong></p>
    <p style="margin:0;">
        <strong>Neodesílejte zboží!</strong> Vyčkejte na potvrzovací e-mail o zaplacení.
        Pokud zákazník do {$order->getExpiresAt()|date:'d.m.Y'} nezaplatí,
        objednávka se automaticky zruší a sklad se Vám vrátí.
    </p>
</div>

<p style="margin:20px 0;">
    <a href="{$baseUrl}/azyl/shopOrder/{$order->getId()}"
       style="display:inline-block;background:#0d6efd;color:white;padding:12px 24px;text-decoration:none;border-radius:6px;font-weight:bold;">
        Zobrazit objednávku
    </a>
</p>

<p style="margin:20px 0 0 0;font-size:12px;color:#666;padding-top:16px;border-top:1px solid #eee;">
    Tento e-mail je informativní - obdržíte ho vždy, když někdo vytvoří objednávku
    ve Vašem eshopu. Potvrzovací e-mail o zaplacení dostanete až poté, co platba
    skutečně dorazí na účet spolku.
</p>
{/block}
