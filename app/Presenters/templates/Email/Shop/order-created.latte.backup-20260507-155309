{layout @layout.latte}

{block title}Objednávka {$order->getOrderNumber()} - čeká na platbu{/block}

{block content}
<h2 style="color:#0d6efd;margin:0 0 16px 0;font-size:20px;">
    Objednávka přijata! 🎉
</h2>

<p style="margin:0 0 16px 0;">Dobrý den {$order->getBuyerName()},</p>

<p style="margin:0 0 16px 0;">
    děkujeme za Vaši objednávku v eshopu Virtuální azyl.
    Přinesete pomoc azylu <strong>{$order->getAzyl()->getAzylName()}</strong>.
</p>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f8f9fa;border-radius:6px;margin:20px 0;">
    <tr>
        <td style="padding:16px 20px;">
            <p style="margin:0 0 8px 0;font-size:14px;color:#666;">Číslo objednávky:</p>
            <p style="margin:0;font-size:22px;font-family:monospace;font-weight:bold;letter-spacing:2px;">
                {$order->getOrderNumber()}
            </p>
        </td>
    </tr>
</table>

<h3 style="margin:24px 0 12px 0;font-size:16px;">Shrnutí objednávky</h3>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse;">
    <thead>
        <tr>
            <th style="text-align:left;padding:8px 0;border-bottom:2px solid #dee2e6;font-size:13px;">Položka</th>
            <th style="text-align:center;padding:8px 0;border-bottom:2px solid #dee2e6;font-size:13px;">Ks</th>
            <th style="text-align:right;padding:8px 0;border-bottom:2px solid #dee2e6;font-size:13px;">Cena</th>
        </tr>
    </thead>
    <tbody>
        {foreach $order->getItems() as $item}
            <tr>
                <td style="padding:8px 0;border-bottom:1px solid #eee;">
                    {$item->getProductName()}
                </td>
                <td style="text-align:center;padding:8px 0;border-bottom:1px solid #eee;">
                    {$item->getQuantity()}
                </td>
                <td style="text-align:right;padding:8px 0;border-bottom:1px solid #eee;">
                    {$item->getSubtotal()|number:0,',','&nbsp;'|noescape} Kč
                </td>
            </tr>
        {/foreach}
    </tbody>
    <tfoot>
        <tr>
            <td colspan="2" style="padding:8px 0;text-align:right;font-size:13px;color:#666;">Poštovné:</td>
            <td style="padding:8px 0;text-align:right;font-size:13px;">
                {$order->getShippingCost()|number:0,',','&nbsp;'|noescape} Kč
            </td>
        </tr>
        <tr>
            <td colspan="2" style="padding:12px 0 0 0;text-align:right;font-weight:bold;font-size:16px;">
                Celkem k úhradě:
            </td>
            <td style="padding:12px 0 0 0;text-align:right;font-weight:bold;font-size:18px;color:#0d6efd;">
                {$order->getTotalAmount()|number:0,',','&nbsp;'|noescape} Kč
            </td>
        </tr>
    </tfoot>
</table>

{* QR platba *}
<div style="background:#e7f3ff;border-left:4px solid #0d6efd;padding:20px;margin:24px 0;border-radius:4px;">
    <h3 style="margin:0 0 12px 0;font-size:16px;color:#0d6efd;">💳 Zaplaťte prosím do {$order->getExpiresAt()|date:'d.m.Y H:i'}</h3>

    {if $qrImage}
        <p style="text-align:center;margin:12px 0;">
            <img src="{$qrImage}" alt="QR platba" style="max-width:220px;height:auto;border:1px solid #dee2e6;background:white;padding:8px;">
        </p>
    {/if}

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="font-size:13px;">
        <tr>
            <td style="padding:4px 0;color:#666;width:40%;">Číslo účtu:</td>
            <td style="padding:4px 0;font-family:monospace;font-weight:bold;">
                {$paymentDetails['account']}/{$paymentDetails['bankCode']}
            </td>
        </tr>
        <tr>
            <td style="padding:4px 0;color:#666;">Částka:</td>
            <td style="padding:4px 0;font-family:monospace;font-weight:bold;">
                {$paymentDetails['amount']|number:2,',','&nbsp;'|noescape} {$paymentDetails['currency']}
            </td>
        </tr>
        <tr>
            <td style="padding:4px 0;color:#666;">Variabilní symbol:</td>
            <td style="padding:4px 0;font-family:monospace;font-weight:bold;font-size:15px;">
                {$paymentDetails['vs']}
            </td>
        </tr>
    </table>

    <p style="margin:16px 0 0 0;font-size:12px;color:#666;">
        ⚠️ Použijte prosím správný variabilní symbol, jinak se platba nepodaří spárovat
        a objednávka se nevyřídí.
    </p>
</div>

<p style="margin:20px 0;">
    <a href="{$baseUrl}/eshop/orderDetail/{$order->getOrderNumber()}"
       style="display:inline-block;background:#0d6efd;color:white;padding:12px 24px;text-decoration:none;border-radius:6px;font-weight:bold;">
        Zobrazit objednávku online
    </a>
</p>

<p style="margin:16px 0 0 0;font-size:12px;color:#666;padding-top:16px;border-top:1px solid #eee;">
    Platba probíhá přes účet spolku Virtuální Azyl, který po odečtu {$order->getFeePercent()}&nbsp;% provize
    částku přepošle azylu. Pokud máte dotazy, odpovězte prosím na tento e-mail.
</p>
{/block}
