{layout @layout.latte}

{block title}Vratka pro objednávku {$order->getOrderNumber()} odeslána{/block}

{block content}
<h2 style="color:#198754;margin:0 0 16px 0;font-size:20px;">
    💸 Vratka odeslána
</h2>

<p style="margin:0 0 16px 0;">Dobrý den {$order->getBuyerName()},</p>

<p style="margin:0 0 16px 0;">
    peníze za stornovanou objednávku <strong>{$order->getOrderNumber()}</strong>
    jsme právě odeslali zpět na váš účet.
</p>

<div style="background:#d1e7dd;border-radius:6px;padding:20px;margin:20px 0;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="font-size:14px;">
        <tr>
            <td style="padding:4px 0;color:#666;">Vrácená částka:</td>
            <td style="padding:4px 0;text-align:right;font-weight:bold;font-size:18px;color:#198754;">
                {$refund->getAmount()|number:2,',','&nbsp;'|noescape} {$refund->getCurrency()}
            </td>
        </tr>
        <tr>
            <td style="padding:4px 0;color:#666;">Na účet:</td>
            <td style="padding:4px 0;text-align:right;font-family:monospace;">
                {$refund->getRefundAccount()}/{$refund->getRefundBankCode()}
            </td>
        </tr>
        <tr>
            <td style="padding:4px 0;color:#666;">Datum odeslání:</td>
            <td style="padding:4px 0;text-align:right;">
                {$refund->getSentAt()|date:'d.m.Y'}
            </td>
        </tr>
    </table>
</div>

<p style="margin:0 0 16px 0;font-size:13px;color:#666;">
    Peníze se zpravidla objeví na vašem účtu do 1-3 pracovních dnů.
</p>

<p style="margin:20px 0 0 0;font-size:13px;color:#666;padding-top:16px;border-top:1px solid #eee;">
    Omlouváme se za komplikace. Pokud vás náš eshop zaujal, rádi vás uvítáme u další objednávky.
</p>
{/block}
