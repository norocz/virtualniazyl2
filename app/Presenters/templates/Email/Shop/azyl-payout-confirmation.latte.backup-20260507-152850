{layout @layout.latte}

{block title}Potvrzení o výplatě {$periodFrom|date:'d.m.Y'} - {$periodTo|date:'d.m.Y'}{/block}

{block content}
<h2 style="color:#198754;margin:0 0 16px 0;font-size:20px;">
    💰 Potvrzení o výplatě
</h2>

<p style="margin:0 0 16px 0;">Dobrý den,</p>

<p style="margin:0 0 16px 0;">
    v tomto e-mailu potvrzujeme výplaty spolku pro azyl <strong>{$azylName}</strong>
    za období <strong>{$periodFrom|date:'d.m.Y'} - {$periodTo|date:'d.m.Y'}</strong>.
</p>

<div style="background:#d1e7dd;border-radius:6px;padding:20px;margin:20px 0;text-align:center;">
    <p style="margin:0 0 4px 0;font-size:13px;color:#666;">Celkem vyplaceno:</p>
    <p style="margin:0;font-size:28px;font-weight:bold;color:#198754;">
        {$totalAmount|number:2,',','&nbsp;'|noescape} Kč
    </p>
    <p style="margin:4px 0 0 0;font-size:12px;color:#666;">
        {count($payouts)} plateb
    </p>
</div>

<h3 style="margin:24px 0 12px 0;font-size:16px;">Detail jednotlivých plateb</h3>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border-collapse:collapse;font-size:13px;">
    <thead>
        <tr style="background:#f8f9fa;">
            <th style="text-align:left;padding:8px;border:1px solid #dee2e6;">Datum</th>
            <th style="text-align:left;padding:8px;border:1px solid #dee2e6;">Objednávka</th>
            <th style="text-align:right;padding:8px;border:1px solid #dee2e6;">Vypl. částka</th>
        </tr>
    </thead>
    <tbody>
        {foreach $payouts as $p}
            <tr>
                <td style="padding:6px 8px;border:1px solid #dee2e6;">
                    {$p->getSentAt()|date:'d.m.Y'}
                </td>
                <td style="padding:6px 8px;border:1px solid #dee2e6;font-family:monospace;">
                    {$p->getOrder()->getOrderNumber()}
                </td>
                <td style="padding:6px 8px;border:1px solid #dee2e6;text-align:right;">
                    {$p->getAmount()|number:2,',','&nbsp;'|noescape} Kč
                </td>
            </tr>
        {/foreach}
    </tbody>
    <tfoot>
        <tr style="background:#f8f9fa;font-weight:bold;">
            <td colspan="2" style="padding:10px 8px;border:1px solid #dee2e6;text-align:right;">
                Celkem:
            </td>
            <td style="padding:10px 8px;border:1px solid #dee2e6;text-align:right;color:#198754;">
                {$totalAmount|number:2,',','&nbsp;'|noescape} Kč
            </td>
        </tr>
    </tfoot>
</table>

<div style="background:#fff3cd;border-left:4px solid #ffc107;padding:16px 20px;margin:24px 0;border-radius:4px;font-size:13px;">
    <p style="margin:0 0 6px 0;">
        📋 <strong>Pro účetní:</strong>
    </p>
    <p style="margin:0;">
        Tento e-mail slouží jako doklad o příjmu. Výpis z bankovního účtu je
        primárním dokladem pro daňové účely. V případě potřeby vám můžeme
        vygenerovat podrobný PDF doklad - kontaktujte shop@virtualniazyl.cz.
    </p>
</div>

<p style="margin:20px 0 0 0;font-size:13px;color:#666;padding-top:16px;border-top:1px solid #eee;">
    Děkujeme, že pomáháte zvířatům! 🐾<br>
    Tým Virtuální azyl z.s.
</p>
{/block}
