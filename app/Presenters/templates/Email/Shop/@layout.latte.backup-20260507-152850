{**
 * Základní layout e-mailů pro eshop.
 * Inline CSS (klient nepodporuje externí styly) a
 * kompatibilita s Outlook / Gmail / Seznam.
 *}
<!DOCTYPE html>
<html lang="{$lang ?? 'cs'}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{block title}Virtuální azyl{/block}</title>
</head>
<body style="margin:0;padding:0;background:#f6f6f6;font-family:Arial,Helvetica,sans-serif;color:#333333;line-height:1.5;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#f6f6f6;padding:20px 0;">
    <tr>
        <td align="center">

            {* Hlavička *}
            <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;background:#0d6efd;border-radius:8px 8px 0 0;">
                <tr>
                    <td style="padding:24px;text-align:center;">
                        <h1 style="color:#ffffff;margin:0;font-size:22px;font-weight:bold;">
                            🐾 Virtuální azyl
                        </h1>
                    </td>
                </tr>
            </table>

            {* Obsah *}
            <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;background:#ffffff;">
                <tr>
                    <td style="padding:32px 28px;">
                        {include content}
                    </td>
                </tr>
            </table>

            {* Patička *}
            <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;background:#f0f0f0;border-radius:0 0 8px 8px;">
                <tr>
                    <td style="padding:20px 28px;text-align:center;font-size:12px;color:#666666;">
                        <p style="margin:0 0 8px 0;">
                            <strong>Virtuální azyl z.s.</strong><br>
                            Pomáháme azylům a zvířatům
                        </p>
                        <p style="margin:8px 0 0 0;">
                            <a href="{$baseUrl}" style="color:#0d6efd;text-decoration:none;">
                                virtualniazyl.cz
                            </a>
                            &nbsp;|&nbsp;
                            <a href="{$baseUrl}/eshop" style="color:#0d6efd;text-decoration:none;">
                                Eshop
                            </a>
                            &nbsp;|&nbsp;
                            <a href="{$baseUrl}/page/polici" style="color:#0d6efd;text-decoration:none;">
                                Podmínky
                            </a>
                        </p>
                    </td>
                </tr>
            </table>

        </td>
    </tr>
</table>

</body>
</html>
