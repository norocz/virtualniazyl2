{**
 * Univerzální layout pro PDF doklady.
 * Inline CSS - mPDF má trochu jinou interpretaci než browser.
 *}
<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <title>{block title}{/block}</title>
    <style>
        @page { size: A4; margin: 0; }
        body {
            font-family: dejavusans, sans-serif;
            font-size: 10pt;
            color: #222;
            line-height: 1.4;
        }
        h1 { font-size: 22pt; margin: 0 0 2mm 0; color: #0d4d8f; }
        h2 { font-size: 14pt; margin: 0 0 2mm 0; color: #0d4d8f; }
        h3 { font-size: 11pt; margin: 4mm 0 2mm 0; text-transform: uppercase; letter-spacing: 1px; color: #666; }
        .muted { color: #888; }
        .small { font-size: 9pt; }
        .xsmall { font-size: 8pt; }

        table.header { width: 100%; margin-bottom: 10mm; }
        table.parties { width: 100%; margin-bottom: 8mm; }
        table.parties td { vertical-align: top; width: 50%; padding: 3mm 4mm; }
        table.parties .party-box {
            border: 1px solid #e0e0e0;
            background: #fafafa;
            padding: 3mm 4mm;
            border-radius: 2mm;
        }

        table.items { width: 100%; border-collapse: collapse; margin: 6mm 0; }
        table.items th {
            background: #0d4d8f;
            color: #fff;
            padding: 2.5mm 3mm;
            text-align: left;
            font-size: 9pt;
            font-weight: normal;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        table.items td {
            padding: 2.5mm 3mm;
            border-bottom: 0.25mm solid #e0e0e0;
        }
        table.items tr:nth-child(even) td { background: #fafafa; }
        table.items .num { text-align: right; }
        table.items .center { text-align: center; }

        table.totals { width: 60%; margin-left: 40%; margin-top: 6mm; }
        table.totals td { padding: 1.5mm 3mm; }
        table.totals tr.grand { border-top: 0.5mm solid #0d4d8f; font-weight: bold; font-size: 12pt; color: #0d4d8f; }

        .details-table { width: 100%; margin: 4mm 0; }
        .details-table td { padding: 1mm 3mm 1mm 0; vertical-align: top; }
        .details-table .label { color: #666; width: 35%; }

        .info-box {
            border-left: 1mm solid #0d6efd;
            background: #f0f7ff;
            padding: 3mm 4mm;
            margin: 6mm 0;
            font-size: 9pt;
        }
        .warning-box {
            border-left: 1mm solid #ffc107;
            background: #fffaeb;
            padding: 3mm 4mm;
            margin: 6mm 0;
            font-size: 9pt;
        }

        .footer-text {
            font-size: 8pt;
            color: #888;
            border-top: 0.25mm solid #e0e0e0;
            padding-top: 3mm;
            margin-top: 10mm;
        }

        .stamp {
            display: inline-block;
            padding: 2mm 4mm;
            border: 0.75mm solid #28a745;
            color: #28a745;
            font-weight: bold;
            font-size: 14pt;
            text-transform: uppercase;
            transform: rotate(-4deg);
        }

        .brand {
            font-weight: bold;
            color: #0d4d8f;
        }
    </style>
</head>
<body>

{include content}

<div class="footer-text">
    {if $doc->getIssuerRegistration()}
        {$doc->getIssuerRegistration()}
        <br>
    {/if}
    Vystaveno elektronicky - doklad je platný bez podpisu a razítka.
    Vygenerováno {$doc->getCreatedAt()|date:'d.m.Y H:i'}.
</div>

</body>
</html>
